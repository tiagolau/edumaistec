# ===========================================
# Supabase (PostgreSQL)
# ===========================================
# Conexão direta — obter em: Supabase Dashboard > Project Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
# Mesma URL — usada pelo Prisma para migrations
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ===========================================
# Eduno EAD API
# ===========================================
# Produção (ava07 — painel admin acessível):
EDUNO_API_BASE_URL=https://ava07.eduno.com.br/api
# Alternativo (ava05 — empresa GLT, sem acesso ao painel):
# EDUNO_API_BASE_URL=https://ava05.eduno.com.br/api
EDUNO_API_TOKEN=token_fornecido_pela_eduno

# Eduno - Identificadores do parceiro
EDUNO_SELLER_CPF=00000000000
EDUNO_CAMPAIGN_ID=0
EDUNO_POLO_CODE=WEB

# ===========================================
# App
# ===========================================
NEXT_PUBLIC_SITE_URL=https://www.edumaistec.com.br

# ===========================================
# Cron Job (Vercel) — Segurança
# ===========================================
CRON_SECRET=gerar_um_secret_seguro_aqui

# ===========================================
# Trackings (Meta Pixel + Meta CAPI + GTM)
# ===========================================
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
META_CAPI_ACCESS_TOKEN=EAA...
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Webhooks do formulário de captação de lead do hero
# Principal: DataCrazy CRM
DATACRAZY_LEAD_WEBHOOK_URL=https://api.datacrazy.io/v1/crm/api/crm/integrations/webhook/business/SUBSTITUIR
# Secundário/backup (n8n, make, outro CRM)
EDUMAISTEC_LEAD_WEBHOOK_URL=https://seu-webhook-backup.example.com/lead

# ===========================================
# Supabase Storage (Landing Page Generator)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
